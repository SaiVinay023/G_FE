# Docker ignore file for a Next.js project
# Improves build speed and security

# Version control
.git
.github
.gitignore

# Dependencies
node_modules
npm-debug.log
yarn-debug.log
yarn-error.log

# Build outputs
.next
out

# Environment files
.env
.env.local
.env.development
.env.test
.env.production
.env.*

# Docker files
Dockerfile
.dockerignore

# Development tools
.vscode
.idea
*.swp
*.swo

# Testing
coverage
.nyc_output
test-results/

# Miscellaneous
.DS_Store
*.log
README.md
LICENSE
.editorconfig
